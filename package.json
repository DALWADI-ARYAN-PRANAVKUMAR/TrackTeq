{
  "name": "track-teq",
  "version": "1.0.0",
  "description": "Track-Teq Monorepo",
  "scripts": {
    "install:all": "npm install && cd frontend && npm install",
    "start:frontend": "cd frontend && npm run dev",
    "start:backend": "cd backend && .\\venv\\Scripts\\python.exe -m uvicorn app.main:app --host 0.0.0.0 --port 8000",
    "dev": "concurrently \"npm run start:frontend\" \"npm run start:backend\""
  },
  "devDependencies": {
    "concurrently": "^8.2.2"
  }
}
